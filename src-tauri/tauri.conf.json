{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "推送姬",
  "version": "../package.json",
  "identifier": "com.xchongsu.tuisongji",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2MDVEMDM5MDk0MTA0NjkKUldScEJFRUpPZEFGZG56REVkcTd1T3o4alNyUHN6MHJMZk02NExMM0Y1R1RnT0Y5K3Y5TzJXS2MK",
      "endpoints": [
        "https://github.com/tuisongji-app/tuisongji/releases/latest/download/latest.json"
      ]
    }
  }
}
